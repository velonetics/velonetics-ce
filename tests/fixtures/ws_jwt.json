{
  "version": 3,
  "port": 8080,
  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[VELONETICS]",
      "stdout": true
    },
    "telemetry/usage": {
      "enabled": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/ws/secure",
      "method": "GET",
      "backend": [
        {
          "host": ["ws://127.0.0.1:8081"],
          "url_pattern": "/",
          "disable_host_sanitize": true
        }
      ],
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "audience": ["http://api.example.com"],
          "roles_key": "roles",
          "issuer": "http://example.com",
          "roles": ["role_a", "role_b"],
          "jwk_url": "http://127.0.0.1:8081/jwk/symmetric",
          "disable_jwk_security": true,
          "cache": true
        },
        "websocket": {
          "enable_direct_communication": true,
          "max_message_size": 4096,
          "input_headers": ["Authorization"],
          "timeout": "30s"
        }
      }
    }
  ]
}
