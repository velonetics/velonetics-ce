{
  "version": 3,
  "port": 8080,
  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "stdout": true
    },
    "telemetry/usage": {
      "enabled": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/review/{id_show}",
      "method": "POST",
      "backend": [
        {
          "host": ["http://127.0.0.1:4000"],
          "url_pattern": "/graphql",
          "extra_config": {
            "backend/graphql": {
              "type": "mutation",
              "query": "mutation CreateReviewForEpisode($ep: Episode!, $review: ReviewInput!) { createReview(episode: $ep, review: $review) { stars commentary } }",
              "variables": {
                "ep": "JEDI",
                "review": {
                  "stars": 3,
                  "commentary": "meh"
                }
              },
              "operationName": "CreateReviewForEpisode"
            }
          }
        }
      ]
    }
  ]
}
