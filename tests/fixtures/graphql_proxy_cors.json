{
  "version": 3,
  "port": 8080,
  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "stdout": true
    },
    "telemetry/usage": {
      "enabled": false
    },
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["POST", "GET", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type"],
      "max_age": "12h"
    }
  },
  "endpoints": [
    {
      "endpoint": "/graphql",
      "method": "POST",
      "input_query_strings": ["query", "operationName", "variables"],
      "backend": [
        {
          "host": ["http://127.0.0.1:4000"],
          "url_pattern": "/graphql"
        }
      ]
    }
  ]
}
