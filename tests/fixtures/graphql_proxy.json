{
  "version": 3,
  "port": 8080,
  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "stdout": true
    },
    "telemetry/usage": {
      "enabled": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/graphql",
      "method": "POST",
      "input_query_strings": ["query", "operationName", "variables"],
      "backend": [
        {
          "host": ["http://127.0.0.1:4000"],
          "url_pattern": "/graphql"
        }
      ]
    }
  ]
}
