{
  "$schema": "https://velonetics.io/schema/v2.13/velonetics.json",
  "version": 3,
  "port": 8080,
  "extra_config": {
    "grpc": {
      "catalog": ["./tests/fixtures/grpcatalog/flights.pb"],
      "server": {
        "services": [
          {
            "name": "flight_finder.Flights",
            "methods": [
              {
                "name": "FindFlight",
                "input_headers": ["*"],
                "backend": [
                  {
                    "host": ["localhost:4242"],
                    "url_pattern": "/flight_finder.Flights/FindFlight",
                    "extra_config": {
                      "backend/grpc": {
                        "use_request_body": true
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "endpoints": [
    {
      "endpoint": "/flights",
      "method": "GET",
      "input_query_strings": ["lat", "lon"],
      "backend": [
        {
          "host": ["localhost:4242"],
          "url_pattern": "/flight_finder.Flights/FindFlight",
          "extra_config": {
            "backend/grpc": {
              "input_mapping": {
                "lat": "where.latitude",
                "lon": "where.longitude"
              }
            }
          }
        }
      ]
    }
  ]
}
