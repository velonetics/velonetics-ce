{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Pucora Helm Chart Values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "config": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["configmap", "secret", "image"]
        }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "nlb": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 }
      }
    },
    "keda": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "sidecarInjection": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "tests": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "configCheck": { "type": "boolean" }
      }
    }
  }
}
