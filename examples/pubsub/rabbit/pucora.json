{
  "$schema": "https://pucora.io/schema/v2.13/pucora.json",
  "version": 3,
  "name": "Pucora RabbitMQ pub/sub example",
  "port": 8080,
  "extra_config": {
    "telemetry/logging": {
      "level": "WARNING",
      "stdout": true
    },
    "telemetry/usage": {
      "enabled": false
    }
  },
  "endpoints": [
    {
      "endpoint": "/publish",
      "method": "POST",
      "backend": [
        {
          "host": ["rabbit://"],
          "url_pattern": "/ignored",
          "disable_host_sanitize": true,
          "extra_config": {
            "backend/pubsub/publisher": {
              "topic_url": "events"
            }
          }
        }
      ]
    },
    {
      "endpoint": "/subscribe",
      "method": "GET",
      "backend": [
        {
          "host": ["rabbit://"],
          "url_pattern": "/ignored",
          "disable_host_sanitize": true,
          "encoding": "json",
          "extra_config": {
            "backend/pubsub/subscriber": {
              "subscription_url": "events"
            }
          }
        }
      ]
    }
  ]
}
